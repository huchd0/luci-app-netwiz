case "$1" in
    list)
        echo '{ "set_network": { "mode": "string", "arg1": "string", "arg2": "string", "arg3": "string", "arg4": "string" }, "confirm": {} }'
        exit 0
        ;;
    call)
        case "$2" in
            # 前端页面成功加载时，会调用此接口拆弹
            confirm)
                if [ -f /tmp/netwiz_pending_confirm ]; then
                    rm -f /tmp/netwiz_pending_confirm /tmp/network.netwiz_bak /tmp/dhcp.netwiz_bak
                    logger -t Netwiz "SUCCESS: Bomb defused by frontend."
                    echo '{"result":0}'
                else
                    logger -t Netwiz "WARNING: Confirm called but no pending bomb found."
                    echo '{"result":0}'
                fi
                exit 0
                ;;
                
            set_network)
                input=$(cat)
                mode=$(echo "$input" | jsonfilter -e '@.mode')
                arg1=$(echo "$input" | jsonfilter -e '@.arg1')
                arg2=$(echo "$input" | jsonfilter -e '@.arg2')
                arg3=$(echo "$input" | jsonfilter -e '@.arg3')
                arg4=$(echo "$input" | jsonfilter -e '@.arg4')

                cleanup_lan_for_wan_modes() {
                    uci delete network.lan.gateway 2>/dev/null
                    uci delete network.lan.dns 2>/dev/null
                    uci set dhcp.lan.ignore='0'
                }
                
                # （省略前面的清理逻辑）
                CURRENT_LAN_IP=$(uci -q get network.lan.ipaddr | cut -d/ -f1)

                if [ "$mode" = "lan" ] && [ -n "$arg1" ] && [ "$arg1" != "$CURRENT_LAN_IP" ]; then
                    logger -t Netwiz "LAN IP changed to $arg1. Arming 2-min radar bomb."
                    
                    cp /etc/config/network /tmp/network.netwiz_bak
                    cp /etc/config/dhcp /tmp/dhcp.netwiz_bak
                    
                    # 生成炸弹脚本（自带 netstat 雷达）
                    cat << 'EOF' > /tmp/netwiz_rollback_task.sh
#!/bin/sh
TARGET_LAN_IP="$1"
sleep 10
# 扫描 110 次，大约 2 分钟
for i in $(seq 1 110); do
    # 🌟 雷达扫描：只要看到有设备连上了新 IP 的网页端口，立刻安全拆弹！
    if netstat -tn 2>/dev/null | grep -E "(^|[ \t:])${TARGET_LAN_IP}:(80|443)[ \t]+.*ESTABLISHED" >/dev/null; then
        logger -t Netwiz "SUCCESS: Browser access detected on $TARGET_LAN_IP. Bomb defused."
        rm -f /tmp/network.netwiz_bak /tmp/dhcp.netwiz_bak /tmp/netwiz_rollback_task.sh
        exit 0
    fi
    sleep 1
done

# 时间到，回退
logger -t Netwiz "Rollback triggered! No web access to $TARGET_LAN_IP detected within 2 minutes."
cp /tmp/network.netwiz_bak /etc/config/network
cp /tmp/dhcp.netwiz_bak /etc/config/dhcp
rm -f /tmp/network.netwiz_bak /tmp/dhcp.netwiz_bak /tmp/netwiz_rollback_task.sh
/etc/init.d/network restart
EOF
                    chmod +x /tmp/netwiz_rollback_task.sh
                    # 把炸弹扔进后台并启动
                    /tmp/netwiz_rollback_task.sh "$arg1" </dev/null >/dev/null 2>&1 &
                fi

                if [ "$mode" = "wan_dhcp" ]; then
                    cleanup_lan_for_wan_modes
                    uci set network.wan.proto='dhcp'
                    uci commit network
                    uci commit dhcp
                elif [ "$mode" = "wan_static" ]; then
                    cleanup_lan_for_wan_modes
                    uci set network.wan.proto='static'
                    uci set network.wan.ipaddr="$arg1"
                    uci set network.wan.gateway="$arg2"
                    uci set network.wan.netmask="$arg3"
                    uci commit network
                    uci commit dhcp
                elif [ "$mode" = "pppoe" ]; then
                    cleanup_lan_for_wan_modes
                    uci set network.wan.proto='pppoe'
                    uci set network.wan.username="$arg1"
                    uci set network.wan.password="$arg2"
                    uci commit network
                    uci commit dhcp
                elif [ "$mode" = "lan" ]; then
                    uci set network.lan.proto='static'
                    uci set network.lan.ipaddr="$arg1"
                    uci set network.lan.netmask="$arg3"
                    if [ -n "$arg2" ]; then
                        uci set network.lan.gateway="$arg2"
                    else
                        uci delete network.lan.gateway 2>/dev/null
                    fi
                    if [ "$arg4" = "1" ]; then
                        uci set dhcp.lan.ignore='1'
                        [ -n "$arg2" ] && uci set network.lan.dns="$arg2"
                    else
                        uci set dhcp.lan.ignore='0'
                        uci delete network.lan.dns 2>/dev/null
                    fi
                    uci commit network
                    uci commit dhcp
                fi
                
                echo '{"result":0}'
                ( exec >/dev/null 2>&1 </dev/null; sleep 3; /etc/init.d/network restart; /etc/init.d/dnsmasq restart ) &
                exit 0
                ;;
        esac
        ;;
esac
exit 1
